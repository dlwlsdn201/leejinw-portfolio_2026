---
import { getCollection } from 'astro:content';
import CareerTimeline from './CareerTimeline';

const careerEntries = await getCollection('career');
const sortedEntries = careerEntries.sort((a, b) => a.data.order - b.data.order);
const items = sortedEntries.map(entry => entry.data);
---
<section id="career" class="min-h-screen w-full snap-start flex flex-col items-center justify-center bg-dark-surface md:py-20 py-4 relative overflow-visible">
  <div class="px-6 z-10 w-full pt-2 md:pt-12 scrollbar-hide">
    <div class="text-center mb-8 md:mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white inline-block relative">
        Career Journey
        <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-12 h-1 bg-blue-500 rounded-full"></div>
      </h2>
    </div>
    
    <CareerTimeline items={items} client:visible />
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
