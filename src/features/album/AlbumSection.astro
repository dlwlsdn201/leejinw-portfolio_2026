---
import AlbumGrid from './AlbumGrid';
---
<section id="album" class="min-h-screen w-full snap-start flex flex-col items-center justify-center bg-dark-surface py-20 relative overflow-hidden">
  <div class="absolute top-1/2 left-0 w-96 h-96 bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-6xl w-full px-6 z-10 overflow-y-auto max-h-screen pt-12 pb-24 scrollbar-hide">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-white inline-block relative">
        My life
        <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-12 h-1 bg-blue-500 rounded-full"></div>
      </h2>
      <p class="text-gray-400 mt-6 text-lg">저의 일상을 공유합니다.</p>
    </div>
    
    <AlbumGrid client:visible />
  </div>
</section>
